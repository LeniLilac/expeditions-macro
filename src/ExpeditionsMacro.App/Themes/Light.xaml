<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="CanvasColor">#F4F5F5</Color>
    <Color x:Key="SidebarColor">#ECEEEF</Color>
    <Color x:Key="SurfaceColor">#FAFAFA</Color>
    <Color x:Key="RaisedColor">#EEF0F1</Color>
    <Color x:Key="HoverColor">#E6E8E9</Color>
    <Color x:Key="SelectedColor">#DDE0E2</Color>
    <Color x:Key="BorderColor">#D2D5D7</Color>
    <Color x:Key="TextColor">#181A1C</Color>
    <Color x:Key="MutedColor">#646A70</Color>
    <Color x:Key="FaintColor">#858B90</Color>
    <Color x:Key="AccentColor">#5F68E8</Color>
    <Color x:Key="OnAccentColor">#FFFFFF</Color>
    <Color x:Key="SuccessColor">#247A55</Color>
    <Color x:Key="WarningColor">#926A1A</Color>
    <Color x:Key="ErrorColor">#B13E48</Color>
    <SolidColorBrush x:Key="CanvasBrush" Color="{StaticResource CanvasColor}" />
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="RaisedBrush" Color="{StaticResource RaisedColor}" />
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverColor}" />
    <SolidColorBrush x:Key="SelectedBrush" Color="{StaticResource SelectedColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}" />
    <SolidColorBrush x:Key="FaintBrush" Color="{StaticResource FaintColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="OnAccentBrush" Color="{StaticResource OnAccentColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
</ResourceDictionary>
