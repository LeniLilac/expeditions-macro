<UserControl x:Class="ExpeditionsMacro.App.Pages.CameraModelsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="238" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid Margin="12,18,12,14">
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <Grid Margin="6,0,6,10">
                    <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}" Text="CAMERA MODELS" />
                    <Button HorizontalAlignment="Right" Style="{StaticResource IconButton}" Width="32" MinWidth="32" Height="32" Content="&#xE710;" ToolTip="New model" Click="NewModel_Click" />
                </Grid>
                <ListBox x:Name="ModelsList" Grid.Row="1" DisplayMemberPath="Name" SelectionChanged="ModelsList_SelectionChanged" />
                <Button Grid.Row="2" Style="{StaticResource DangerButton}" Content="Delete selected" Click="DeleteModel_Click" />
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="34,28,42,34" MaxWidth="900" HorizontalAlignment="Left">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Margin="0,0,0,24">
                    <TextBlock Style="{StaticResource PageTitle}" Text="Camera models" />
                </StackPanel>

                <Border Grid.Row="1" Style="{StaticResource SectionDivider}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Goal view" />
                        <TextBlock Margin="0,5,0,18" MaxWidth="640" HorizontalAlignment="Left" Style="{StaticResource Caption}" Text="Setup finds several stable, detailed map areas automatically and ignores the usual HUD zones. The colored outlines show what the model compares." />
                        <StackPanel MaxWidth="640" HorizontalAlignment="Stretch">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Model name" />
                                <Button x:Name="RenameButton" Grid.Column="1" Height="30" MinWidth="82" Content="Rename" IsEnabled="False" Click="Rename_Click" />
                            </Grid>
                            <TextBox x:Name="ModelNameText" Margin="0,7,0,12" Text="Camera model" />
                            <Border Height="190" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                                <Grid>
                                    <Image x:Name="PreviewImage" Margin="1" Stretch="Uniform" />
                                    <TextBlock x:Name="PreviewPlaceholder" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource FaintBrush}" Text="Automatic regions appear after setup" />
                                </Grid>
                            </Border>
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock x:Name="RegionText" Style="{StaticResource Caption}" Text="Automatic regions: chosen during setup" />
                                <StackPanel Margin="0,8,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
                                    <Button x:Name="OverlayButton" Content="Show 30% overlay" IsEnabled="False" Click="Overlay_Click" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource SectionDivider}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,20,0">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="Calibration" />
                                <TextBlock Margin="0,5,0,0" MaxWidth="640" HorizontalAlignment="Left" Style="{StaticResource Caption}" Text="Setup zooms fully out, sets a top-down pitch, learns a fine goal neighborhood, then learns one complete turn with Right-arrow pulses." TextWrapping="Wrap" />
                            </StackPanel>
                            <Button x:Name="CalibrationToggle" Grid.Column="1" Height="34" Content="Show tuning" Click="CalibrationToggle_Click" />
                        </Grid>
                        <Grid x:Name="CalibrationPanel" Margin="0,18,0,0" MaxWidth="640" HorizontalAlignment="Stretch" Visibility="Collapsed">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="16" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition Height="66" /><RowDefinition Height="66" /><RowDefinition Height="66" /></Grid.RowDefinitions>
                            <StackPanel><TextBlock Style="{StaticResource FieldLabel}" Text="Goal captures" /><TextBox x:Name="CaptureCountText" Margin="0,7,0,0" Text="12" /></StackPanel>
                            <StackPanel Grid.Column="2"><TextBlock Style="{StaticResource FieldLabel}" Text="Capture time, seconds" /><TextBox x:Name="CaptureSecondsText" Margin="0,7,0,0" Text="3.0" /></StackPanel>
                            <StackPanel Grid.Row="1"><TextBlock Style="{StaticResource FieldLabel}" Text="Arrow hold, ms" /><TextBox x:Name="ArrowHoldText" Margin="0,7,0,0" Text="30" /></StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2"><TextBlock Style="{StaticResource FieldLabel}" Text="Fine drag, pixels" /><TextBox x:Name="FinePixelsText" Margin="0,7,0,0" Text="1" /></StackPanel>
                            <StackPanel Grid.Row="2"><TextBlock Style="{StaticResource FieldLabel}" Text="Settle time, ms" /><TextBox x:Name="SettleText" Margin="0,7,0,0" Text="100" /></StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="2"><TextBlock Style="{StaticResource FieldLabel}" Text="Maximum arrow samples" /><TextBox x:Name="MaxSamplesText" Margin="0,7,0,0" Text="300" /></StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="3">
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitle}" Text="Operation" />
                            <TextBlock x:Name="StatusText" Margin="0,5,0,0" Style="{StaticResource Caption}" Text="Ready to create an automatic multi-region model." />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Margin="0,12,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
                            <Button x:Name="SetupButton" Style="{StaticResource PrimaryButton}" Content="Setup model" Click="Setup_Click" />
                            <Button x:Name="AlignButton" Margin="8,0,0,0" Content="Auto align" IsEnabled="False" Click="Align_Click" />
                            <Button x:Name="StopButton" Margin="8,0,0,0" Style="{StaticResource DangerButton}" Content="Stop" IsEnabled="False" Click="Stop_Click" />
                        </StackPanel>
                    </Grid>
                    <ProgressBar x:Name="OperationProgress" Grid.Row="1" Margin="0,16,0,0" Minimum="0" Maximum="100" Value="0" />
                    <Border Grid.Row="2" Margin="0,14,0,0" Height="120" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                        <TextBox x:Name="LogText" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" BorderThickness="0" FontFamily="Cascadia Mono, Consolas" FontSize="11" />
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
