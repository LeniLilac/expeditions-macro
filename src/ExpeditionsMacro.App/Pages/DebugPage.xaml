<UserControl x:Class="ExpeditionsMacro.App.Pages.DebugPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="clr-namespace:ExpeditionsMacro.App.Controls">
    <Grid Margin="34,28,38,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{StaticResource PageTitle}"
                           Text="Debug" />
                <TextBlock Margin="0,5,0,0"
                           Style="{StaticResource Caption}"
                           Text="Run one owned workflow at a time. Previous only reviews captured checkpoints; it never reverses Roblox input." />
            </StackPanel>
            <StackPanel Grid.Column="1"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <Ellipse x:Name="DebugStateDot"
                         Width="8"
                         Height="8"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center"
                         Fill="{DynamicResource FaintBrush}" />
                <TextBlock x:Name="DebugStateText"
                           VerticalAlignment="Center"
                           Style="{StaticResource Caption}"
                           Text="Ready" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource FormCard}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitle}"
                                       Text="Play navigation" />
                            <TextBlock Margin="0,14,0,0"
                                       Style="{StaticResource FieldLabel}"
                                       Text="Start state" />
                            <ComboBox x:Name="NavigationStartCombo"
                                      Margin="0,7,0,0"
                                      DisplayMemberPath="Label" />
                            <TextBlock Margin="0,12,0,0"
                                       Style="{StaticResource FieldLabel}"
                                       Text="Mode" />
                            <ComboBox x:Name="NavigationModeCombo"
                                      Margin="0,7,0,0"
                                      DisplayMemberPath="Label"
                                      SelectionChanged="NavigationMode_Changed" />
                            <TextBlock Margin="0,12,0,0"
                                       Style="{StaticResource FieldLabel}"
                                       Text="Preset" />
                            <ComboBox x:Name="NavigationPresetCombo"
                                      Margin="0,7,0,0"
                                      DisplayMemberPath="Name" />
                            <StackPanel x:Name="ChallengeTypePanel"
                                        Margin="0,12,0,0"
                                        Visibility="Collapsed">
                                <TextBlock Style="{StaticResource FieldLabel}"
                                           Text="Challenge type" />
                                <ComboBox x:Name="ChallengeTypeCombo"
                                          Margin="0,7,0,0" />
                            </StackPanel>
                            <Button x:Name="RunNavigationButton"
                                    Margin="0,16,0,0"
                                    HorizontalAlignment="Right"
                                    Style="{StaticResource PrimaryButton}"
                                    icons:Lucide.Icon="Route"
                                    Content="Test navigation"
                                    Click="RunNavigation_Click" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,14,0,0"
                            Style="{StaticResource FormCard}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitle}"
                                       Text="Team swap" />
                            <TextBlock Margin="0,14,0,0"
                                       Style="{StaticResource FieldLabel}"
                                       Text="Saved team" />
                            <ComboBox x:Name="TeamCombo"
                                      Margin="0,7,0,0"
                                      DisplayMemberPath="Label" />
                            <Button x:Name="RunTeamButton"
                                    Margin="0,16,0,0"
                                    HorizontalAlignment="Right"
                                    Style="{StaticResource PrimaryButton}"
                                    icons:Lucide.Icon="Users"
                                    Content="Test team swap"
                                    Click="RunTeam_Click" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,14,0,0"
                            Style="{StaticResource FormCard}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitle}"
                                       Text="Utilities" />
                            <Button x:Name="InspectScreenButton"
                                    Margin="0,14,0,0"
                                    HorizontalAlignment="Stretch"
                                    icons:Lucide.Icon="ScanSearch"
                                    Content="Inspect current screen"
                                    Click="InspectScreen_Click" />
                            <Button x:Name="NormalizeClientButton"
                                    Margin="0,8,0,0"
                                    HorizontalAlignment="Stretch"
                                    icons:Lucide.Icon="ScanLine"
                                    Content="Focus and standardize Roblox"
                                    Click="NormalizeClient_Click" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="260" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource FormCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Width="220"
                                    HorizontalAlignment="Left">
                            <TextBlock Style="{StaticResource FieldLabel}"
                                       Text="Live checkpoint mode" />
                            <ComboBox x:Name="StepModeCombo"
                                      Margin="0,7,0,0"
                                      DisplayMemberPath="Label" />
                        </StackPanel>
                        <Button x:Name="StopButton"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Height="34"
                                icons:Lucide.Icon="Square"
                                Content="Stop"
                                Click="Stop_Click" />
                        <StackPanel Grid.Row="1"
                                    Margin="0,12,0,0"
                                    Orientation="Horizontal">
                            <Button x:Name="PreviousButton"
                                    Width="38"
                                    Height="34"
                                    MinWidth="0"
                                    icons:Lucide.Icon="ChevronLeft"
                                    ToolTip="Review previous checkpoint"
                                    Click="Previous_Click" />
                            <Button x:Name="NextReviewButton"
                                    Width="38"
                                    Height="34"
                                    MinWidth="0"
                                    Margin="6,0,0,0"
                                    icons:Lucide.Icon="ChevronRight"
                                    ToolTip="Review next captured checkpoint"
                                    Click="NextReview_Click" />
                            <Button x:Name="PauseButton"
                                    Height="34"
                                    Margin="12,0,0,0"
                                    icons:Lucide.Icon="Pause"
                                    Content="Pause next"
                                    Click="Pause_Click" />
                            <Button x:Name="StepButton"
                                    Height="34"
                                    Margin="6,0,0,0"
                                    icons:Lucide.Icon="StepForward"
                                    Content="Step"
                                    Click="Step_Click" />
                            <Button x:Name="ResumeButton"
                                    Height="34"
                                    Margin="6,0,0,0"
                                    icons:Lucide.Icon="FastForward"
                                    Content="Fast-forward"
                                    Click="Resume_Click" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="5"
                        ClipToBounds="True">
                    <Grid>
                        <Image x:Name="CheckpointImage"
                               Stretch="Uniform" />
                        <TextBlock x:Name="NoFrameText"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource Caption}"
                                   Text="A captured Roblox frame will appear here." />
                    </Grid>
                </Border>

                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <TextBlock x:Name="CheckpointTitle"
                                   Style="{StaticResource SectionTitle}"
                                   Text="Checkpoint timeline" />
                        <TextBlock x:Name="CheckpointPosition"
                                   HorizontalAlignment="Right"
                                   Style="{StaticResource Caption}"
                                   Text="0 of 0" />
                    </Grid>
                    <ListBox x:Name="TimelineList"
                             Grid.Row="2"
                             BorderThickness="0"
                             Background="Transparent"
                             SelectionChanged="Timeline_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Foreground="{DynamicResource FaintBrush}"
                                               Text="{Binding Sequence}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="{Binding Title}" />
                                        <TextBlock Margin="0,2,0,0"
                                                   Style="{StaticResource Caption}"
                                                   Text="{Binding Detail}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
