<UserControl x:Class="ExpeditionsMacro.App.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             PreviewKeyDown="SettingsPage_PreviewKeyDown">
    <ScrollViewer x:Name="SettingsScroll" VerticalScrollBarVisibility="Auto">
        <Grid Margin="34,28,42,34" MaxWidth="900" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Margin="0,0,0,28">
                <TextBlock Style="{StaticResource PageTitle}" Text="Settings" />
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource SectionDivider}">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="220" /><ColumnDefinition Width="420" /></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Appearance" />
                        <TextBlock Margin="0,5,24,0" Style="{StaticResource Caption}" Text="System follows the Windows app theme and updates while the utility is open." />
                    </StackPanel>
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions><RowDefinition Height="48" /><RowDefinition Height="48" /></Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Theme" />
                        <ComboBox x:Name="ThemeCombo" Width="180" HorizontalAlignment="Right" SelectionChanged="ThemeCombo_SelectionChanged" />
                        <CheckBox x:Name="MinimizeCheck" Grid.Row="1" VerticalAlignment="Center" Content="Minimize this utility while automation is running" Checked="MinimizeCheck_Changed" Unchecked="MinimizeCheck_Changed" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource SectionDivider}">
                <StackPanel Width="640" HorizontalAlignment="Left">
                    <TextBlock Style="{StaticResource SectionTitle}" Text="Controls" />
                    <TextBlock Margin="0,5,0,0" Style="{StaticResource Caption}" TextWrapping="Wrap" Text="Choose a global start and stop key, then set the separate letter assigned to Toggle Play Menu in Anime Expeditions." />
                    <Grid Margin="0,16,0,0">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Macro hotkey" />
                            <TextBlock x:Name="HotkeyStatusText" Margin="0,5,180,0" Style="{StaticResource Caption}" TextWrapping="Wrap" Text="Click the button, then press a letter, number, punctuation key, numpad key, or function key." />
                        </StackPanel>
                        <Button x:Name="HotkeyButton" Width="160" HorizontalAlignment="Right" Content="F6" Click="HotkeyButton_Click" />
                    </Grid>
                    <Grid Margin="0,14,0,0">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Play menu key" />
                            <TextBlock x:Name="PlayMenuKeyStatusText" Margin="0,5,180,0" Style="{StaticResource Caption}" TextWrapping="Wrap" Text="Required before a macro can start." />
                        </StackPanel>
                        <Button x:Name="PlayMenuKeyButton"
                                Width="160"
                                HorizontalAlignment="Right"
                                Content="Set key"
                                Click="PlayMenuKeyButton_Click" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource SectionDivider}">
                <StackPanel Width="640" HorizontalAlignment="Left">
                    <TextBlock Style="{StaticResource SectionTitle}" Text="UI scale calibration" />
                    <TextBlock Margin="0,5,0,0" Style="{StaticResource Caption}" TextWrapping="Wrap" Text="Compare Roblox's rendered interface with the standard detector scale. The overlay stays click-through while you adjust UI Scale in Roblox settings." />
                    <Grid Margin="0,16,0,0">
                        <TextBlock x:Name="UiScaleOverlayStatusText" MaxWidth="390" HorizontalAlignment="Left" VerticalAlignment="Center" Style="{StaticResource Caption}" TextWrapping="Wrap" Text="Roblox will be resized to the standard 808 by 611 client size." />
                        <Button x:Name="UiScaleOverlayButton" Width="180" HorizontalAlignment="Right" Content="Show calibration overlay" Click="UiScaleOverlayButton_Click" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource SectionDivider}">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="220" /><ColumnDefinition Width="420" /></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Local data" />
                        <TextBlock Margin="0,5,24,0" Style="{StaticResource Caption}" Text="Models, presets, detector packs, secrets, and logs stay under your Windows profile." />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBox x:Name="DataPath" IsReadOnly="True" />
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Open data folder" Click="OpenData_Click" />
                            <Button Margin="8,0,0,0" Content="Open logs" Click="OpenLogs_Click" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="5" Style="{StaticResource SectionDivider}">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="220" /><ColumnDefinition Width="420" /></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Detector pack" />
                        <TextBlock Margin="0,5,24,0" Style="{StaticResource Caption}" Text="Compact references are loaded locally. An installed pack is never replaced during an active run." />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <Border Padding="12" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                            <StackPanel>
                                <TextBlock x:Name="DetectorTitle" FontWeight="SemiBold" Text="Loading detector pack" />
                                <TextBlock x:Name="DetectorDetail" Margin="0,4,0,0" Style="{StaticResource Caption}" />
                            </StackPanel>
                        </Border>
                        <Grid Margin="0,10,0,0">
                            <CheckBox x:Name="AutoUpdateCheck" VerticalAlignment="Center" Content="Check once per day" Checked="AutoUpdateCheck_Changed" Unchecked="AutoUpdateCheck_Changed" />
                            <Button HorizontalAlignment="Right" Content="Check for updates" Click="RefreshDetector_Click" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="6" Style="{StaticResource SectionDivider}">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="220" /><ColumnDefinition Width="420" /></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Diagnostics" />
                        <TextBlock Margin="0,5,24,0" Style="{StaticResource Caption}" Text="Read-only checks for the local automation environment." />
                    </StackPanel>
                    <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                        <StackPanel>
                            <Grid Margin="12,10"><TextBlock Foreground="{DynamicResource MutedBrush}" Text="Application" /><TextBlock x:Name="VersionText" HorizontalAlignment="Right" /></Grid>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" />
                            <Grid Margin="12,10"><TextBlock Foreground="{DynamicResource MutedBrush}" Text="Roblox window" /><TextBlock x:Name="RobloxText" HorizontalAlignment="Right" /></Grid>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" />
                            <Grid Margin="12,10"><TextBlock Foreground="{DynamicResource MutedBrush}" Text="Global hotkey" /><TextBlock x:Name="HotkeyText" HorizontalAlignment="Right" /></Grid>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" />
                            <Grid Margin="12,10"><TextBlock Foreground="{DynamicResource MutedBrush}" Text="Play menu key" /><TextBlock x:Name="PlayMenuKeyDiagnosticText" HorizontalAlignment="Right" /></Grid>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" />
                            <Grid Margin="12,10"><TextBlock Foreground="{DynamicResource MutedBrush}" Text="Runtime" /><TextBlock HorizontalAlignment="Right" Text=".NET 10, Windows x64" /></Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <StackPanel Grid.Row="7" Width="640" HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource SectionTitle}" Text="Debug capture" />
                <TextBlock x:Name="DebugCaptureDescription" Margin="0,5,0,0" Style="{StaticResource Caption}" Text="Record the Roblox client at the standard 808 by 611 size. F6 starts and stops capture and saves a ZIP for bug reports." />
                <CheckBox x:Name="AutoCaptureOnErrorCheck" Margin="0,14,0,0" Content="Automatically save 10 screenshots when a macro fails" Checked="AutoCaptureOnErrorCheck_Changed" Unchecked="AutoCaptureOnErrorCheck_Changed" />
                <TextBlock Margin="25,5,0,0" Style="{StaticResource Caption}" TextWrapping="Wrap" Text="Captures one Roblox-client frame per second in a timestamped ZIP. Manual Stop does not create a capture." />
                <CheckBox x:Name="IncludeLogsCheck" Margin="0,12,0,0" Content="Include the current macro run log in diagnostic ZIPs" Checked="IncludeLogsCheck_Changed" Unchecked="IncludeLogsCheck_Changed" />
                <TextBlock Margin="25,5,0,0" Style="{StaticResource Caption}" TextWrapping="Wrap" Text="Applies to manual and automatic captures. Review the log before sharing because it can contain local paths and operational details." />
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="16" /><ColumnDefinition Width="170" /></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Capture name" />
                        <TextBox x:Name="CaptureNameText" Margin="0,7,0,0" Text="diagnostic-capture" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Interval, seconds" />
                        <TextBox x:Name="CaptureIntervalText" Margin="0,7,0,0" Text="1.0" />
                    </StackPanel>
                </Grid>
                <Grid Margin="0,14,0,0">
                    <TextBlock x:Name="CaptureStatusText" MaxWidth="300" HorizontalAlignment="Left" VerticalAlignment="Center" Style="{StaticResource Caption}" Text="Ready to arm a diagnostic capture." />
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button Content="Open captures" Click="OpenCaptures_Click" />
                        <Button x:Name="CaptureArmButton" Margin="8,0,0,0" Style="{StaticResource PrimaryButton}" Content="Arm capture" Click="CaptureArm_Click" />
                        <Button x:Name="CaptureStopButton" Margin="8,0,0,0" Content="Stop and save" IsEnabled="False" Click="CaptureStop_Click" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
