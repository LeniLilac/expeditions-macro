<UserControl x:Class="ExpeditionsMacro.App.Pages.RaidPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="clr-namespace:ExpeditionsMacro.App.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24,20,32,28"
              MaxWidth="1280"
              HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource FormCard}">
                <StackPanel>
                    <TextBlock Style="{StaticResource PageTitle}" Text="Raid" />
                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Preset" />
                        <ComboBox x:Name="PresetCombo"
                                  Grid.Column="1"
                                  DisplayMemberPath="Name"
                                  SelectionChanged="PresetCombo_SelectionChanged" />
                        <Button x:Name="SavePresetButton"
                                Grid.Column="2"
                                Margin="12,0,0,0"
                                icons:Lucide.Icon="Save"
                                Content="Save preset"
                                Click="Save_Click" />
                        <Button x:Name="NewPresetButton"
                                Grid.Column="3"
                                Margin="10,0,0,0"
                                icons:Lucide.Icon="Plus"
                                Content="New"
                                Click="New_Click" />
                        <Button x:Name="DeletePresetButton"
                                Grid.Column="4"
                                Margin="10,0,0,0"
                                Style="{StaticResource DangerButton}"
                                icons:Lucide.Icon="Trash2"
                                Content="Delete"
                                IsEnabled="False"
                                Click="DeletePreset_Click" />
                    </Grid>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource FormCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Spirit City" />
                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="54" />
                                <RowDefinition Height="54" />
                                <RowDefinition Height="54" />
                                <RowDefinition Height="54" />
                            </Grid.RowDefinitions>
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Preset name" />
                            <TextBox x:Name="NameText" Grid.Column="1" Text="Raid route" />
                            <TextBlock Grid.Row="1" Style="{StaticResource FieldLabel}" Text="Act" />
                            <ComboBox x:Name="ActCombo"
                                      Grid.Row="1"
                                      Grid.Column="1"
                                      DisplayMemberPath="Name" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource FormCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Models and team" />
                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="54" />
                                <RowDefinition Height="54" />
                                <RowDefinition Height="54" />
                                <RowDefinition Height="54" />
                                <RowDefinition Height="54" />
                            </Grid.RowDefinitions>
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Camera model" />
                            <ComboBox x:Name="CameraCombo"
                                      Grid.Column="1"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id" />
                            <TextBlock Grid.Row="1" Style="{StaticResource FieldLabel}" Text="Before-start placement" />
                            <ComboBox x:Name="PrestartCombo"
                                      Grid.Row="1"
                                      Grid.Column="1"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id" />
                            <TextBlock Grid.Row="2" Style="{StaticResource FieldLabel}" Text="After-start placement" />
                            <ComboBox x:Name="DelayedCombo"
                                      Grid.Row="2"
                                      Grid.Column="1"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id" />
                            <TextBlock Grid.Row="3" Style="{StaticResource FieldLabel}" Text="After-start delay, sec" />
                            <TextBox x:Name="DelayText"
                                     Grid.Row="3"
                                     Grid.Column="1"
                                     Text="30" />
                            <TextBlock Grid.Row="4" Style="{StaticResource FieldLabel}" Text="Team" />
                            <ComboBox x:Name="TeamCombo"
                                      Grid.Row="4"
                                      Grid.Column="1"
                                      DisplayMemberPath="Name" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Margin="0,14,0,0"
                    Style="{StaticResource FormCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Retries after defeat" />
                    <TextBox x:Name="RetriesText" Grid.Column="1" Text="0" />
                    <CheckBox x:Name="AutoRecoverCheck"
                              Grid.Column="3"
                              IsChecked="True"
                              Content="Return after lobby, disconnect, or AFK recovery" />
                </Grid>
            </Border>

            <Border Grid.Row="3"
                    Margin="0,14,0,0"
                    Style="{StaticResource FormCard}">
                <StackPanel>
                    <Grid>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Timing and camera preparation" />
                        <Button x:Name="TuningToggle"
                                HorizontalAlignment="Right"
                                Height="40"
                                icons:Lucide.Icon="SlidersHorizontal"
                                Content="Show tuning"
                                Click="TuningToggle_Click" />
                    </Grid>
                    <Grid x:Name="TuningPanel"
                          Margin="0,18,0,0"
                          Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Zoom ticks" />
                            <TextBox x:Name="ZoomText" Margin="0,7,0,0" Text="30" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Pitch drag, px" />
                            <TextBox x:Name="PitchText" Margin="0,7,0,0" Text="1800" />
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Detection, ms" />
                            <TextBox x:Name="PollText" Margin="0,7,0,0" Text="450" />
                        </StackPanel>
                        <StackPanel Grid.Column="6">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Stable frames" />
                            <TextBox x:Name="StableText" Margin="0,7,0,0" Text="2" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock x:Name="StatusText"
                       Grid.Row="4"
                       Margin="0,10,0,0"
                       FontWeight="SemiBold" />
        </Grid>
    </ScrollViewer>
</UserControl>
