<UserControl x:Class="ExpeditionsMacro.App.Pages.MacroPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="clr-namespace:ExpeditionsMacro.App.Controls">
    <ScrollViewer x:Name="PageScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="34,27,40,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Margin="0,0,24,0"
                           Style="{StaticResource PageTitle}"
                           Text="Macro" />
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button x:Name="StartButton" Style="{StaticResource PrimaryButton}" icons:Lucide.Icon="Play" Content="Start plan  F6" Click="Start_Click" />
                    <Button x:Name="StopButton" Margin="8,0,0,0" Style="{StaticResource DangerButton}" icons:Lucide.Icon="Square" Content="Stop plan  F6" IsEnabled="False" Click="Stop_Click" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Padding="0,0,0,18" Margin="0,0,0,22" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="230" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Plan" />
                    <ComboBox x:Name="PlanCombo" Grid.Column="1" DisplayMemberPath="Name" SelectionChanged="PlanCombo_SelectionChanged" />
                    <TextBox x:Name="PlanNameText" Grid.Column="3" Text="Daily rotation" />
                    <Button Grid.Column="4" Margin="8,0,0,0" icons:Lucide.Icon="Save" Content="Save plan" Click="SavePlan_Click" />
                    <Button Grid.Column="5" Margin="8,0,0,0" icons:Lucide.Icon="Plus" Content="New" Click="NewPlan_Click" />
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource SectionDivider}">
                <StackPanel>
                    <Grid>
                        <TextBlock Style="{StaticResource SectionTitle}"
                                   Text="Priority queue" />
                        <Button x:Name="ResetProgressButton" HorizontalAlignment="Right" Height="34" icons:Lucide.Icon="RotateCcw" Content="Reset progress" Click="ResetProgress_Click" />
                    </Grid>

                    <Border Margin="0,14,0,0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                        <StackPanel>
                            <Grid Height="38" Background="{DynamicResource RaisedBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="38" />
                                    <ColumnDefinition Width="92" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="168" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Margin="12,0,6,0" VerticalAlignment="Center" Style="{StaticResource Caption}" Text="#" />
                                <TextBlock Grid.Column="1" Margin="6,0" VerticalAlignment="Center" Style="{StaticResource Caption}" Text="Mode" />
                                <TextBlock Grid.Column="2" Margin="6,0" VerticalAlignment="Center" Style="{StaticResource Caption}" Text="Preset" />
                                <TextBlock Grid.Column="3" Margin="6,0" VerticalAlignment="Center" Style="{StaticResource Caption}" Text="Target" />
                                <TextBlock Grid.Column="4" Margin="6,0" VerticalAlignment="Center" Style="{StaticResource Caption}" Text="Progress" />
                                <TextBlock Grid.Column="5" Margin="6,0" VerticalAlignment="Center" Style="{StaticResource Caption}" Text="Actions" />
                            </Grid>
                            <ItemsControl x:Name="TaskRowsControl" ItemsSource="{Binding TaskRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                                            <Grid MinHeight="50">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="38" />
                                                    <ColumnDefinition Width="92" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="168" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Margin="12,0,6,0" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}" Text="{Binding Definition.Priority}" />
                                                <TextBlock Grid.Column="1" Margin="6,0" VerticalAlignment="Center" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Text="{Binding Type}" />
                                                <TextBlock Grid.Column="2" Margin="6,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Text="{Binding Name}" />
                                                <TextBlock Grid.Column="3" Margin="6,0" VerticalAlignment="Center" Style="{StaticResource Caption}" Text="{Binding Target}" />
                                                <TextBlock Grid.Column="4" Margin="6,0" VerticalAlignment="Center" Style="{StaticResource Caption}" Text="{Binding Status}" />
                                                <StackPanel Grid.Column="5" Margin="4,7" HorizontalAlignment="Center" Orientation="Horizontal">
                                                    <Button Width="34" MinWidth="34" Height="34" Style="{StaticResource IconButton}" icons:Lucide.Icon="ArrowUp" AutomationProperties.Name="Move task up" ToolTip="Move task up" Tag="{Binding}" Click="MoveTaskUp_Click" />
                                                    <Button Width="34" MinWidth="34" Height="34" Margin="5,0,0,0" Style="{StaticResource IconButton}" icons:Lucide.Icon="ArrowDown" AutomationProperties.Name="Move task down" ToolTip="Move task down" Tag="{Binding}" Click="MoveTaskDown_Click" />
                                                    <Button Width="34" MinWidth="34" Height="34" Margin="5,0,0,0" Style="{StaticResource IconButton}" icons:Lucide.Icon="Pencil" AutomationProperties.Name="Edit task" ToolTip="Edit task" Tag="{Binding}" Click="EditTask_Click" />
                                                    <Button Width="34" MinWidth="34" Height="34" Margin="5,0,0,0" Style="{StaticResource IconButton}" icons:Lucide.Icon="Trash2" AutomationProperties.Name="Remove task" ToolTip="Remove task" Tag="{Binding}" Click="RemoveTask_Click" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="EmptyTasksText" Margin="12" Style="{StaticResource Caption}" Text="No tasks yet. Add a preset below." />
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="112" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Mode" />
                            <ComboBox x:Name="TaskKindCombo" Margin="0,7,0,0" DisplayMemberPath="Name" SelectionChanged="TaskKindCombo_SelectionChanged" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Preset" />
                            <ComboBox x:Name="TaskPresetCombo" Margin="0,7,0,0" DisplayMemberPath="DisplayName" SelectionChanged="TaskPresetCombo_SelectionChanged" />
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock x:Name="TaskTargetLabel" Style="{StaticResource FieldLabel}" Text="Victories" />
                            <TextBox x:Name="TaskTargetText" Margin="0,7,0,0" Text="1" />
                        </StackPanel>
                        <StackPanel Grid.Column="6">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="State" />
                            <CheckBox x:Name="TaskEnabledCheck" Margin="0,7,0,0" IsChecked="True" Content="Enabled" />
                        </StackPanel>
                        <Button x:Name="AddTaskButton" Grid.Column="8" Margin="0,21,0,0" VerticalAlignment="Top" Style="{StaticResource PrimaryButton}" icons:Lucide.Icon="Plus" Content="Add task" Click="AddOrUpdateTask_Click" />
                        <Button x:Name="CancelTaskEditButton" Grid.Column="10" Margin="0,21,0,0" Height="40" VerticalAlignment="Top" Visibility="Collapsed" icons:Lucide.Icon="X" Content="Cancel" Click="CancelTaskEdit_Click" />
                    </Grid>
                    <TextBlock x:Name="TaskEditorStatusText" Margin="0,8,0,0" Style="{StaticResource Caption}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource FormCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Discord notifications" />
                        <TextBlock Margin="0,18,0,0" Style="{StaticResource FieldLabel}" Text="Webhook link" />
                        <Border Margin="0,7,0,0" Style="{StaticResource InputGroup}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="48" />
                                </Grid.ColumnDefinitions>
                                <PasswordBox x:Name="WebhookPassword"
                                             Style="{StaticResource InputGroupPasswordBox}" />
                                <TextBox x:Name="WebhookVisible"
                                         Style="{StaticResource InputGroupTextBox}"
                                         Visibility="Collapsed" />
                                <Button x:Name="TestWebhookButton"
                                        Grid.Column="1"
                                        Height="32"
                                        Margin="4"
                                        icons:Lucide.Icon="Send"
                                        Content="Test webhook"
                                        Click="TestWebhook_Click" />
                                <CheckBox x:Name="ShowWebhookCheck"
                                          Grid.Column="2"
                                          Margin="4"
                                          Style="{StaticResource RevealToggle}"
                                          AutomationProperties.Name="Show webhook link"
                                          ToolTip="Show or hide webhook link"
                                          Checked="ShowWebhook_Changed"
                                          Unchecked="ShowWebhook_Changed" />
                            </Grid>
                        </Border>
                        <TextBlock x:Name="WebhookStatusText"
                                   Margin="0,8,0,0"
                                   Style="{StaticResource Caption}" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Background="{DynamicResource BorderBrush}" />
                    <StackPanel Grid.Column="2" Margin="24,0,0,0">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Failure alert ping" />
                        <TextBlock Margin="0,18,0,0" Style="{StaticResource FieldLabel}" Text="Discord user ID" />
                        <TextBox x:Name="DiscordUserIdText" Margin="0,7,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="4"
                    Margin="0,14,0,0"
                    Style="{StaticResource FormCard}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="Roblox reconnect" />
                    <CheckBox x:Name="RestartRobloxCheck"
                              Margin="0,14,0,0"
                              Content="Restart Roblox through this private server when recovery fails" />
                    <TextBlock Margin="0,18,0,0"
                               Style="{StaticResource FieldLabel}"
                               Text="Private server link" />
                    <Border Margin="0,7,0,0" Style="{StaticResource InputGroup}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="48" />
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="PrivateServerLinkPassword"
                                         Style="{StaticResource InputGroupPasswordBox}" />
                            <TextBox x:Name="PrivateServerLinkVisible"
                                     Style="{StaticResource InputGroupTextBox}"
                                     Visibility="Collapsed" />
                            <Button x:Name="TestPrivateServerButton"
                                    Grid.Column="1"
                                    Height="32"
                                    Margin="4"
                                    icons:Lucide.Icon="ExternalLink"
                                    Content="Test link"
                                    Click="TestPrivateServer_Click" />
                            <CheckBox x:Name="ShowPrivateServerLinkCheck"
                                      Grid.Column="2"
                                      Margin="4"
                                      Style="{StaticResource RevealToggle}"
                                      AutomationProperties.Name="Show private server link"
                                      ToolTip="Show or hide private server link"
                                      Checked="ShowPrivateServerLink_Changed"
                                      Unchecked="ShowPrivateServerLink_Changed" />
                        </Grid>
                    </Border>
                    <TextBlock x:Name="PrivateServerStatusText" Margin="0,7,0,0" Style="{StaticResource Caption}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Row="5" Margin="0,22,0,0">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,24,0">
                            <TextBlock x:Name="PhaseText" FontSize="15" FontWeight="SemiBold" Text="Ready to run a saved plan." />
                            <TextBlock x:Name="CurrentTaskText" Margin="0,4,0,0" Style="{StaticResource Caption}" Text="Current task: none" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <StackPanel Width="105"><TextBlock Style="{StaticResource Caption}" Text="Runtime" /><TextBlock x:Name="RuntimeText" Margin="0,3,0,0" FontWeight="SemiBold" Text="00:00:00" /></StackPanel>
                            <StackPanel Width="88"><TextBlock Style="{StaticResource Caption}" Text="Victories" /><TextBlock x:Name="VictoriesText" Margin="0,3,0,0" FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}" Text="0" /></StackPanel>
                            <StackPanel Width="82"><TextBlock Style="{StaticResource Caption}" Text="Defeats" /><TextBlock x:Name="DefeatsText" Margin="0,3,0,0" FontWeight="SemiBold" Foreground="{DynamicResource ErrorBrush}" Text="0" /></StackPanel>
                        </StackPanel>
                    </Grid>
                    <ProgressBar x:Name="MacroProgress" Margin="0,13,0,12" Minimum="0" Maximum="100" />
                    <Border MinHeight="130" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                        <TextBox x:Name="LogText" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" BorderThickness="0" FontSize="11" />
                    </Border>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>
