<Window x:Class="ExpeditionsMacro.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:icons="clr-namespace:ExpeditionsMacro.App.Controls"
        Title="Expeditions Macro"
        Icon="Resources/app.ico"
        Style="{StaticResource AppWindow}"
        Width="1200" Height="780" MinWidth="960" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResizeWithGrip"
        Closing="Window_Closing">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="42" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <Grid Background="{DynamicResource CanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="42" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource SidebarBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" MouseRightButtonUp="TitleBar_RightClick">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="216" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="14,0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Width="23" Height="23" Margin="0,0,9,0" Source="Resources/app-preview.png" />
                    <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="Expeditions Macro" />
                </StackPanel>
                <TextBlock x:Name="TitleContext" Grid.Column="1" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}" Text="Macro" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource IconButton}" Width="44" Height="41" BorderThickness="0" Background="Transparent" icons:Lucide.Icon="Minus" ToolTip="Minimize" Click="Minimize_Click" />
                    <Button x:Name="MaximizeButton" Style="{StaticResource IconButton}" Width="44" Height="41" BorderThickness="0" Background="Transparent" icons:Lucide.Icon="Square" ToolTip="Maximize" Click="Maximize_Click" />
                    <Button Style="{StaticResource IconButton}" Width="44" Height="41" BorderThickness="0" Background="Transparent" icons:Lucide.Icon="X" ToolTip="Close" Click="Close_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="216" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Margin="18,18,18,7" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource FaintBrush}" Text="WORKSPACE" />
                    <StackPanel Grid.Row="1">
                        <RadioButton x:Name="MacroNav" GroupName="Navigation" Style="{StaticResource NavigationItem}" IsChecked="True" Tag="Macro" icons:Lucide.Icon="Workflow" Content="Macro" Checked="Navigation_Checked" />
                        <TextBlock Margin="18,18,18,7" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource FaintBrush}" Text="PRESETS" />
                        <RadioButton x:Name="ExpeditionsNav" GroupName="Navigation" Style="{StaticResource NavigationItem}" Tag="Expeditions" icons:Lucide.Icon="Compass" Content="Expeditions" Checked="Navigation_Checked" />
                        <RadioButton x:Name="ChallengesNav" GroupName="Navigation" Style="{StaticResource NavigationItem}" Tag="Challenges" icons:Lucide.Icon="Swords" Content="Challenges" Checked="Navigation_Checked" />
                        <RadioButton x:Name="StoryNav" GroupName="Navigation" Style="{StaticResource NavigationItem}" Tag="Story" icons:Lucide.Icon="BookOpen" Content="Story" Checked="Navigation_Checked" />
                        <RadioButton x:Name="RaidNav" GroupName="Navigation" Style="{StaticResource NavigationItem}" Tag="Raid" icons:Lucide.Icon="Shield" Content="Raid" Checked="Navigation_Checked" />
                        <TextBlock Margin="18,18,18,7" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource FaintBrush}" Text="TOOLS" />
                        <RadioButton x:Name="CameraNav" GroupName="Navigation" Style="{StaticResource NavigationItem}" Tag="Camera Models" icons:Lucide.Icon="Camera" Content="Camera Models" Checked="Navigation_Checked" />
                        <RadioButton x:Name="PlacementNav" GroupName="Navigation" Style="{StaticResource NavigationItem}" Tag="Placement Models" icons:Lucide.Icon="MapPin" Content="Placement Models" Checked="Navigation_Checked" />
                        <RadioButton x:Name="DebugNav" GroupName="Navigation" Style="{StaticResource NavigationItem}" Tag="Debug" icons:Lucide.Icon="Bug" Content="Debug" Visibility="Collapsed" Checked="Navigation_Checked" />
                        <RadioButton x:Name="SettingsNav" GroupName="Navigation" Style="{StaticResource NavigationItem}" Tag="Settings" icons:Lucide.Icon="Settings" Content="Settings" Checked="Navigation_Checked" />
                    </StackPanel>
                    <StackPanel Grid.Row="2">
                        <Button Margin="12,0,12,8" Height="36" MinWidth="0" icons:Lucide.Icon="CircleHelp" Content="Setup guide" ToolTip="Open the setup guide in your browser" Click="SetupGuide_Click" />
                        <Button Margin="12,0,12,8" Height="36" MinWidth="0" icons:Lucide.Icon="MessagesSquare" Content="Join Discord" ToolTip="Open the Expeditions Macro community invite" Click="JoinDiscord_Click" />
                        <Border Margin="12,0,12,6" Padding="10" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="5">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="OperationDot" Width="7" Height="7" Margin="0,0,8,0" VerticalAlignment="Center" Fill="{DynamicResource FaintBrush}" />
                                    <TextBlock x:Name="OperationLabel" MaxWidth="155" TextTrimming="CharacterEllipsis" FontSize="12" Text="Ready" />
                                </StackPanel>
                                <TextBlock x:Name="HotkeyHint" Grid.Row="1" Margin="15,4,0,0" Foreground="{DynamicResource FaintBrush}" FontSize="11" Text="F6 start / stop" />
                            </Grid>
                        </Border>
                        <TextBlock x:Name="VersionLabel" Margin="18,0,18,10" HorizontalAlignment="Center" Foreground="{DynamicResource FaintBrush}" FontSize="10" Text="Version" />
                    </StackPanel>
                </Grid>
            </Border>
            <ContentControl x:Name="PageHost" Grid.Column="1" />
        </Grid>
    </Grid>
</Window>
