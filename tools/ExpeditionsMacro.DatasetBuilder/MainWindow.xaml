<Window x:Class="ExpeditionsMacro.DatasetBuilder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detector Dataset Builder"
        Icon="Resources/app.ico"
        Width="860" Height="590" MinWidth="720" MinHeight="500"
        WindowStyle="None" ResizeMode="CanResizeWithGrip">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="42" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <TextBlock Margin="16,0" VerticalAlignment="Center" FontWeight="SemiBold" Text="Detector Dataset Builder" />
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Width="44" MinWidth="44" Height="41" BorderThickness="0" Content="&#xE921;" FontFamily="Segoe Fluent Icons" Click="Minimize_Click" />
                    <Button Width="44" MinWidth="44" Height="41" BorderThickness="0" Content="&#xE922;" FontFamily="Segoe Fluent Icons" Click="Maximize_Click" />
                    <Button Width="44" MinWidth="44" Height="41" BorderThickness="0" Content="&#xE8BB;" FontFamily="Segoe Fluent Icons" Click="Close_Click" />
                </StackPanel>
            </Grid>
        </Border>
        <Grid Grid.Row="1" Margin="28,24,28,26">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock FontSize="22" FontWeight="SemiBold" Text="Compile detector references" />
            <TextBlock Grid.Row="1" Margin="0,7,0,22" Foreground="{StaticResource MutedBrush}" Text="Build a deterministic, hashed pack from reviewed 808 × 611 Roblox client screenshots." />
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="92" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48" />
                    <RowDefinition Height="48" />
                    <RowDefinition Height="48" />
                </Grid.RowDefinitions>
                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" Text="Screenshot datasets" />
                <TextBox x:Name="DatasetsPath" Grid.Column="1" VerticalAlignment="Center" />
                <Button Grid.Column="2" Margin="8,5,0,5" Content="Browse" Click="BrowseDatasets_Click" />
                <TextBlock Grid.Row="1" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" Text="Pack output" />
                <TextBox x:Name="OutputPath" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" />
                <Button Grid.Row="1" Grid.Column="2" Margin="8,5,0,5" Content="Browse" Click="BrowseOutput_Click" />
                <TextBlock Grid.Row="2" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" Text="Version" />
                <TextBox x:Name="VersionText" Grid.Row="2" Grid.Column="1" Width="180" HorizontalAlignment="Left" VerticalAlignment="Center" Text="1.0.2" />
            </Grid>
            <Border Grid.Row="4" Margin="0,20,0,18" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                <TextBox x:Name="LogText" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" BorderThickness="0" FontFamily="Cascadia Mono, Consolas" FontSize="12" />
            </Border>
            <Grid Grid.Row="5">
                <ProgressBar x:Name="BusyProgress" Width="180" Height="3" HorizontalAlignment="Left" IsIndeterminate="True" Visibility="Collapsed" Foreground="{StaticResource AccentBrush}" />
                <Button x:Name="BuildButton" HorizontalAlignment="Right" Height="42" MinWidth="132" Background="{StaticResource TextBrush}" Foreground="{StaticResource CanvasBrush}" BorderThickness="0" Content="Build detector pack" Click="Build_Click" />
            </Grid>
        </Grid>
    </Grid>
</Window>
