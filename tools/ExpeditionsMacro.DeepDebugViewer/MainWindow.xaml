<Window x:Class="ExpeditionsMacro.DeepDebugViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:icons="clr-namespace:ExpeditionsMacro.DeepDebugViewer.Controls"
        Title="Deep Debug Viewer"
        Width="1280"
        Height="840"
        MinWidth="920"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/ExpeditionsMacro.DeepDebugViewer;component/Resources/app.ico"
        Style="{StaticResource AppWindow}"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        KeyDown="Window_KeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="132" />
        </Grid.RowDefinitions>

        <Border Padding="24,0"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource PageTitle}" Text="Deep Debug Viewer" />
                    <TextBlock Style="{StaticResource Caption}" Text="Replay captured Roblox frames beside the decisions and inputs that produced them." />
                </StackPanel>
                <TextBlock x:Name="ArchivePathText"
                           Grid.Column="1"
                           Margin="28,0"
                           MaxWidth="620"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedBrush}"
                           Text="No archive open"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                <Button Grid.Column="2"
                        Content="Open archive"
                        Click="OpenArchive_Click"
                        icons:ViewerIcon.Icon="FolderOpen" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Padding="24,0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="OperationText"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Text="Drop a Deep Debug ZIP anywhere in this window" />
                <TextBlock x:Name="OutcomeText"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedBrush}"
                           Text="Outcome: unknown" />
                <TextBlock x:Name="RuntimeText"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedBrush}"
                           Text="Runtime: 00:00:00" />
                <TextBlock x:Name="ArchiveCountText"
                           Grid.Column="3"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedBrush}"
                           Text="0 frames  ·  0 events" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="480" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="420" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <Border Margin="24,22,18,22"
                    Background="#090A0A"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <Grid>
                    <Image x:Name="FrameImage"
                           Margin="1"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Stretch="Uniform" />
                    <Border x:Name="PreviewMessageBorder"
                            MaxWidth="420"
                            Padding="18,14"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="{DynamicResource RaisedBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                        <StackPanel>
                            <icons:ViewerIconControl x:Name="PreviewMessageIcon"
                                                     Width="22"
                                                     Height="22"
                                                     Margin="0,0,0,9"
                                                     HorizontalAlignment="Center"
                                                     Foreground="{DynamicResource MutedBrush}"
                                                     Icon="FileArchive" />
                            <TextBlock x:Name="PreviewMessageText"
                                       HorizontalAlignment="Center"
                                       Text="Open or drop a Deep Debug ZIP to begin."
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns" />

            <Border Grid.Column="2"
                    Padding="18,20,18,16"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <icons:ViewerIconControl Width="17"
                                                 Height="17"
                                                 Margin="0,0,8,0"
                                                 Foreground="{DynamicResource MutedBrush}"
                                                 Icon="ListTree" />
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Events near this frame" />
                    </StackPanel>
                    <TextBlock x:Name="EventContextText"
                               Grid.Row="1"
                               Margin="0,7,0,12"
                               Style="{StaticResource Caption}"
                               Text="Actions, detector states, progress, and generated input remain synchronized by sequence." />
                    <ListBox x:Name="EventList" Grid.Row="2">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="EventBorder"
                                        Padding="9,8"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Foreground="{DynamicResource FaintBrush}" Text="{Binding Time}" />
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Heading}" TextWrapping="Wrap" />
                                            <TextBlock Margin="0,3,0,0"
                                                       Foreground="{DynamicResource MutedBrush}"
                                                       Text="{Binding Details}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsCurrentFrame}" Value="True">
                                        <Setter TargetName="EventBorder" Property="Background" Value="{DynamicResource SelectedBrush}" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Padding="24,14,24,16"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock x:Name="FramePathText"
                               Foreground="{DynamicResource MutedBrush}"
                               Text="No frame selected"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="TimestampText"
                               Grid.Column="1"
                               Margin="18,0,0,0"
                               Foreground="{DynamicResource MutedBrush}"
                               Text="--:--:--.---" />
                    <TextBlock x:Name="FramePositionText"
                               Grid.Column="2"
                               Margin="18,0,0,0"
                               FontWeight="SemiBold"
                               Text="0 / 0" />
                </Grid>
                <Slider x:Name="TimelineSlider"
                        Grid.Row="1"
                        Margin="0,6,0,6"
                        IsEnabled="False"
                        IsMoveToPointEnabled="True"
                        Maximum="0"
                        Minimum="0"
                        SmallChange="1"
                        TickFrequency="1"
                        ValueChanged="TimelineSlider_ValueChanged" />
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="PreviousButton"
                                Margin="0,0,8,0"
                                IsEnabled="False"
                                Style="{StaticResource IconButton}"
                                ToolTip="Previous frame (Left arrow)"
                                Click="Previous_Click"
                                icons:ViewerIcon.Icon="ChevronLeft" />
                        <Button x:Name="PlayPauseButton"
                                Margin="0,0,8,0"
                                MinWidth="104"
                                IsEnabled="False"
                                Style="{StaticResource PrimaryButton}"
                                Content="Play"
                                ToolTip="Play or pause (Space)"
                                Click="PlayPause_Click"
                                icons:ViewerIcon.Icon="Play" />
                        <Button x:Name="NextButton"
                                Margin="0,0,16,0"
                                IsEnabled="False"
                                Style="{StaticResource IconButton}"
                                ToolTip="Next frame (Right arrow)"
                                Click="Next_Click"
                                icons:ViewerIcon.Icon="ChevronRight" />
                        <TextBlock Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource MutedBrush}"
                                   Text="Speed" />
                        <ComboBox x:Name="SpeedCombo"
                                  Width="96"
                                  DisplayMemberPath="Label"
                                  SelectionChanged="SpeedCombo_SelectionChanged" />
                    </StackPanel>
                    <TextBlock x:Name="StatusText"
                               Grid.Column="1"
                               Margin="18,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource MutedBrush}"
                               Text="Ready"
                               TextTrimming="CharacterEllipsis" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock x:Name="CacheUsageText"
                                   Margin="0,0,9,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource MutedBrush}"
                                   Text="Cache 0 B / 10 GB" />
                        <ComboBox x:Name="CacheBudgetCombo"
                                  Width="98"
                                  Margin="0,0,8,0"
                                  DisplayMemberPath="Label"
                                  SelectionChanged="CacheBudgetCombo_SelectionChanged" />
                        <Button x:Name="ClearCacheButton"
                                MinWidth="108"
                                IsEnabled="False"
                                Content="Clear cache"
                                ToolTip="Release every cached decoded frame"
                                Click="ClearCache_Click"
                                icons:ViewerIcon.Icon="X" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
