<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="CanvasColor">#0F1010</Color>
    <Color x:Key="SurfaceColor">#181819</Color>
    <Color x:Key="RaisedColor">#252528</Color>
    <Color x:Key="HoverColor">#202123</Color>
    <Color x:Key="SelectedColor">#2B2C30</Color>
    <Color x:Key="BorderColor">#333438</Color>
    <Color x:Key="TextColor">#F0F1F2</Color>
    <Color x:Key="MutedColor">#A1A4A8</Color>
    <Color x:Key="FaintColor">#74777C</Color>
    <Color x:Key="AccentColor">#7780FA</Color>
    <Color x:Key="OnAccentColor">#FFFFFF</Color>
    <Color x:Key="WarningColor">#D6A84B</Color>
    <Color x:Key="ErrorColor">#D96770</Color>
    <SolidColorBrush x:Key="CanvasBrush" Color="{StaticResource CanvasColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="RaisedBrush" Color="{StaticResource RaisedColor}" />
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverColor}" />
    <SolidColorBrush x:Key="SelectedBrush" Color="{StaticResource SelectedColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}" />
    <SolidColorBrush x:Key="FaintBrush" Color="{StaticResource FaintColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="OnAccentBrush" Color="{StaticResource OnAccentColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
</ResourceDictionary>
